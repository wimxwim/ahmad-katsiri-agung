# Google Sheets API — Service Account Credentials
# 1. Buat project di https://console.cloud.google.com
# 2. Enable Google Sheets API
# 3. Buat Service Account → download JSON key
# 4. Copy client_email dan private_key dari JSON key
GOOGLE_SHEETS_CLIENT_EMAIL="service-account-name@project-id.iam.gserviceaccount.com"
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-google-sheet-id"

# Telegram Bot
# 1. Chat @BotFather → /newbot → dapatkan token
# 2. Chat @userinfobot → dapatkan chat_id
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
TELEGRAM_CHAT_ID="123456789"
