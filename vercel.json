{
  "framework": "nextjs",
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        { "type": "host", "value": "ahmad-katsiri-agung.vercel.app" }
      ],
      "missing": [
        { "type": "header", "key": "x-from-worker", "value": "akal-center" }
      ],
      "mitigate": { "action": "deny" }
    }
  ]
}
